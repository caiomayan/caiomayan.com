---
import MainLayout from "../layouts/MainLayout.astro";
const lastUpdated: string = new Date().toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<MainLayout
  textRole="Software Developer"
  ,
  textDescription="Building scalable, on-demand applications from end to end, focused on clean architecture and robust design systems."
  ,
  textCurriculum="See my curriculum here"
  ,
  textUpdatedOn="Updated on"
  ,
  dateLastUpdated={lastUpdated}
  ,
  textOr=" / "
  ,
  metaLang="en"
  ,
  lang="en"
>

  <h1 class="text-4xl font-bold mb-4">Be home</h1>
  <p class="text-lg mb-6">
    I'm a software developer specializing in building scalable, on-demand applications from end to end, focused on clean architecture and robust design systems.
  </p>
  <p class="text-lg">
    Feel free to explore my projects and get in touch if you'd like to collaborate!
  </p>

</MainLayout>
