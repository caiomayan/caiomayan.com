---
import MainLayout from "../layouts/MainLayout.astro";
const lastUpdated: string = new Date().toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<MainLayout
  textRole="Software Developer"
  ,
  textDescription="Building real on demand websites from beginning to end, with cleanest
      architecture and best design systems."
  ,
  textCurriculum="See my curriculum here"
  ,
  textUpdatedOn="Updated on"
  ,
  dateLastUpdated={lastUpdated}
  ,
  textOr=" / "
  ,
  metaLang="en"
  ,
  lang="en"
/>
