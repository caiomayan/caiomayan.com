---
import MainLayout from "../../layouts/MainLayout.astro";
const lastUpdatedPT: string = new Date().toLocaleDateString("pt-BR", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<MainLayout
  textRole="Desenvolvedor de Software"
  ,
  textDescription="Criando sistemas completos de demanda real, com as melhores práticas de arquitetura e código limpo."
  ,
  textCurriculum="Veja meu currículo aqui"
  ,
  textUpdatedOn="Atualizado em"
  ,
  dateLastUpdated={lastUpdatedPT}
  ,
  textOr=" / "
  ,
  metaLang="pt"
  ,
  lang="pt"
/>
